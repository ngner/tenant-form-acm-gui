[
  {
    "type": "console.navigation/href",
    "properties": {
      "id": "create-tenant",
      "name": "Create Tenant",
      "href": "/tenant-create",
      "perspective": "acm"
    }
  },
  {
    "type": "console.page/route",
    "properties": {
      "exact": true,
      "path": "/tenant-create",
      "component": {
        "$codeRef": "CreateTenantPage"
      }
    }
  },
  {
    "type": "console.page/route",
    "properties": {
      "exact": true,
      "path": "/tenant-edit/ns/:ns/:name",
      "component": {
        "$codeRef": "EditTenantPage"
      }
    }
  },
  {
    "type": "console.action/provider",
    "properties": {
      "model": {
        "group": "dusty-seahorse.io",
        "version": "v1alpha1",
        "kind": "Tenant"
      },
      "provider": {
        "$codeRef": "useTenantEditAction"
      }
    }
  }
]
